{
  "expo": {
    "name": "Shopisel",
    "slug": "shopisel",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "shopisel",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366F1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "pt.isel.shopisel",
      "infoPlist": {
        "NSCameraUsageDescription": "Precisamos de acesso a camara para ler codigos de barras.",
        "NSLocationWhenInUseUsageDescription": "Precisamos da tua localizacao para mostrar as lojas mais proximas."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6366F1"
      },
      "package": "pt.isel.shopisel",
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Precisamos de acesso a camara para ler codigos de barras."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Precisamos da tua localizacao para mostrar as lojas mais proximas."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
